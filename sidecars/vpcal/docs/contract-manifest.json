    {
      "operation_id": "export.opentrackio",
      "summary": "Export calibrated tracking data as OpenTrackIO JSONL.",
      "input_schema": {},
      "output_schema": {},
      "error_schema": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
