{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "volo",
  "version": "0.1.0",
  "identifier": "com.lanbipu.volo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Volo",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 20 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/ps-scripts/*.ps1": "ps-scripts",
      "resources/ps-scripts/*.cmd": "ps-scripts",
      "resources/ps-scripts/*.txt": "ps-scripts",
      "resources/vendor": "vendor",
      "../examples": "examples",
      "../target/sidecar-vendor": "sidecar-vendor"
    }
  }
}
